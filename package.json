{
  "name": "limbus-command-simulator",
  "version": "1.0.3",
  "description": "边狱巴士 指令模拟器 — The Index Command Simulator for Limbus Company",
  "author": "冬熊夏鸟",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "fix-data": "node tools/fix-data.js"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.limbus.command-simulator",
    "productName": "谨遵指令",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "renderer/**",
      "data/**",
      "resources/**"
    ],
    "win": {
      "target": "portable",
      "icon": "resources/icon.png",
      "sign": null,
      "signAndEditExecutable": false
    }
  }
}
